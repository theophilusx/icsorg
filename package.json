{
  "name": "icsorg",
  "version": "2.0.0",
  "description": "Import ICS file into org for inclusion in org agenda",
  "main": "src/index.js",
  "bin": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "mocha test/**/*.test.js",
    "test:unit": "mocha test/unit/**/*.test.js",
    "test:integration": "mocha test/integration/**/*.test.js",
    "test:watch": "mocha test/**/*.test.js --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theophilusx/icsorg.git"
  },
  "keywords": [
    "ics",
    "calendar",
    "org-mode"
  ],
  "author": "Tim Cross",
  "email": "theophilusx@gmail.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/theophilusx/icsorg/issues"
  },
  "homepage": "https://github.com/theophilusx/icsorg#readme",
  "dependencies": {
    "dotenv": "^17.2.3",
    "ical-expander": "^3.2.0",
    "luxon": "^3.7.2",
    "minimist": "^1.2.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "chai": "^6.2.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.4",
    "prettier": "^3.6.2"
  }
}
